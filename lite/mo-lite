#!/bin/sh
# mo-lite — minimal mole for OpenWrt / iStoreOS / BusyBox systems.
# POSIX sh only: no arrays, no [[, works under BusyBox ash.
# Commands: clean, analyze [path], status.  Flags: -n dry-run, -y yes.

VERSION="0.4.0"
DRY=0
YES=0

usage() {
  cat <<EOF
mo-lite v$VERSION — minimal mole for OpenWrt-class systems

Usage: mo-lite [-n] [-y] <command>
  clean            free space/RAM: opkg lists, LuCI caches, stray .ipk, rotated logs
  analyze [path]   biggest entries under a path (default /)
  status           one-shot system snapshot from /proc
  -n               dry run (print, delete nothing)
  -y               no confirmation prompts
EOF
}

human() { # KB -> human
  awk -v k="$1" 'BEGIN{
    split("KB MB GB TB", u); s=1
    while (k >= 1024 && s < 4) { k /= 1024; s++ }
    printf (s==1 ? "%d%s" : "%.1f%s"), k, u[s]
  }'
}

confirm() {
  [ "$YES" = 1 ] && return 0
  [ "$DRY" = 1 ] && return 0
  printf '%s [y/N] ' "$1"
  read -r r 2>/dev/null || return 1
  case "$r" in y*|Y*) return 0 ;; *) return 1 ;; esac
}

kb_of() { du -sk "$1" 2>/dev/null | cut -f1; }

rm_path() { # remove one path, honoring dry-run; prints size
  [ -e "$1" ] || return 0
  k=$(kb_of "$1"); k=${k:-0}
  if [ "$DRY" = 1 ]; then
    echo "  [dry-run] would remove $1 ($(human "$k"))"
  else
    rm -rf "$1" && echo "  removed $1 ($(human "$k"))"
  fi
  FREED_KB=$((FREED_KB + k))
}

do_clean() {
  FREED_KB=0
  echo "mo-lite clean"

  # opkg package lists (regenerated by `opkg update`)
  # /var/opkg-lists only: on stock OpenWrt /var is a symlink to /tmp, so
  # listing both paths would show the same directory twice
  if [ -d /var/opkg-lists ]; then
    if confirm "Remove opkg package lists (opkg update restores them)?"; then
      rm_path /var/opkg-lists
    fi
  fi

  # LuCI web-UI caches (regenerated on next page load)
  found=0
  for d in /tmp/luci-modulecache /tmp/luci-indexcache /tmp/luci-indexcache.*; do
    [ -e "$d" ] && found=1
  done
  if [ "$found" = 1 ] && confirm "Remove LuCI caches?"; then
    for d in /tmp/luci-modulecache /tmp/luci-indexcache /tmp/luci-indexcache.*; do
      [ -e "$d" ] && rm_path "$d"
    done
  fi

  # stray downloaded packages
  found=0
  for f in /tmp/*.ipk /tmp/*.apk; do
    [ -f "$f" ] && found=1 && break
  done
  if [ "$found" = 1 ] && confirm "Remove downloaded .ipk/.apk files in /tmp?"; then
    for f in /tmp/*.ipk /tmp/*.apk; do
      [ -f "$f" ] && rm_path "$f"
    done
  fi

  # rotated logs (only on disk-logging setups; /var/log is RAM on stock OpenWrt)
  found=0
  for f in /var/log/*.gz /var/log/*.old /var/log/*.[0-9]; do
    [ -f "$f" ] && found=1 && break
  done
  if [ "$found" = 1 ] && confirm "Remove rotated logs in /var/log?"; then
    for f in /var/log/*.gz /var/log/*.old /var/log/*.[0-9]; do
      [ -f "$f" ] && rm_path "$f"
    done
  fi

  if [ "$DRY" = 1 ]; then
    echo "Would free $(human "$FREED_KB")"
  else
    echo "Freed $(human "$FREED_KB")"
  fi
}

do_analyze() {
  p="${1:-/}"
  [ -d "$p" ] || { echo "not a directory: $p" >&2; exit 1; }
  echo "mo-lite analyze — $p"
  for e in "$p"/* "$p"/.[!.]*; do
    [ -e "$e" ] || continue
    k=$(kb_of "$e")
    [ -n "$k" ] && printf '%s\t%s\n' "$k" "$e"
  done | sort -rn | head -15 | while IFS="$(printf '\t')" read -r k e; do
    printf '  %8s  %s\n' "$(human "$k")" "$e"
  done
}

do_status() {
  echo "mo-lite status"
  # uptime & load
  up=$(awk '{s=int($1); printf "%dd %dh %dm", s/86400, (s%86400)/3600, (s%3600)/60}' /proc/uptime 2>/dev/null)
  load=$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null)
  echo "  up $up   load $load"
  # memory
  awk '/^MemTotal:/{t=$2} /^MemAvailable:/{a=$2} /^MemFree:/{f=$2}
    END{ if (a=="") a=f
         printf "  mem  %.1fMB used / %.1fMB total\n", (t-a)/1024, t/1024 }' /proc/meminfo 2>/dev/null
  # disks (root and overlay — the pair that matters on OpenWrt)
  df -k / /overlay 2>/dev/null | awk 'NR>1 && !seen[$6]++ {
    printf "  disk %s  %.1fMB used / %.1fMB (%s)\n", $6, $3/1024, $2/1024, $5 }'
  # network totals
  awk -F'[: ]+' '/:/{ if ($2 != "lo") { rx += $3; tx += $11 } }
    END{ printf "  net  rx %.1fMB  tx %.1fMB (since boot)\n", rx/1048576, tx/1048576 }' /proc/net/dev 2>/dev/null
  # temperature if exposed
  for z in /sys/class/thermal/thermal_zone*/temp; do
    [ -r "$z" ] && { t=$(cat "$z"); echo "  temp $((t / 1000))°C"; break; }
  done
  return 0
}

CMD=""
for a in "$@"; do
  case "$a" in
    -n) DRY=1 ;;
    -y) YES=1 ;;
    -h|--help) usage; exit 0 ;;
    *) if [ -z "$CMD" ]; then CMD="$a"; else ARG="$a"; fi ;;
  esac
done

case "$CMD" in
  clean)   do_clean ;;
  analyze) do_analyze "${ARG:-}" ;;
  status)  do_status ;;
  *)       usage; exit 1 ;;
esac
