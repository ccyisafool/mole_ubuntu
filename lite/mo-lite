#!/bin/sh
# mo-lite ŌĆö minimal mole for OpenWrt / iStoreOS / BusyBox systems.
# POSIX sh only: no arrays, no [[, works under BusyBox ash.
# Commands: clean, analyze [path], status.  Flags: -n dry-run, -y yes.

VERSION="0.4.4"
DRY=0
YES=0
NAME=${0##*/}

# same visual language as full mole; colors auto-off when piped
if [ -t 1 ]; then
  E=$(printf '\033')
  R="$E[0m"  B="$E[1m"  D="$E[2m"
  RED="$E[31m" GRN="$E[32m" YLW="$E[33m" BLU="$E[34m" MAG="$E[35m" CYN="$E[36m"
else
  R='' B='' D='' RED='' GRN='' YLW='' BLU='' MAG='' CYN=''
fi

section() { printf '\n%sŌ¢Ė %s%s\n' "$B$BLU" "$*" "$R"; }
info()    { printf '  %s\n' "$*"; }

usage() {
  cat <<EOF
${B}$NAME${R} v$VERSION (mole-lite) ŌĆö minimal mole for OpenWrt-class systems

${B}Usage:${R} $NAME [-n] [-y] <command>
  clean            free space/RAM: opkg lists, LuCI caches, stray .ipk, rotated logs
  analyze [path]   biggest entries under a path (default /)
  status           one-shot system snapshot from /proc
  update           replace this script with the latest from GitHub
  -n               dry run (print, delete nothing)
  -y               no confirmation prompts
EOF
}

human() { # KB -> human
  awk -v k="${1:-0}" 'BEGIN{
    split("KB MB GB TB", u); s=1
    while (k >= 1024 && s < 4) { k /= 1024; s++ }
    printf (s==1 ? "%d%s" : "%.1f%s"), k, u[s]
  }'
}

meter() { # pct [width] -> colored bar
  awk -v p="${1:-0}" -v w="${2:-16}" -v g="$GRN" -v y="$YLW" -v r="$RED" -v d="$D" -v z="$R" 'BEGIN{
    if (p<0) p=0; if (p>100) p=100
    f = int(p*w/100)
    c = p<60 ? g : (p<85 ? y : r)
    printf "%s", c;   for (i=0;i<f;i++) printf "Ō¢ł"
    printf "%s%s", z, d; for (i=f;i<w;i++) printf "Ō¢æ"
    printf "%s", z
  }'
}

confirm() {
  [ "$YES" = 1 ] && return 0
  [ "$DRY" = 1 ] && return 0
  printf '  %s%s%s [y/N] ' "$B" "$1" "$R"
  read -r r 2>/dev/null || return 1
  case "$r" in y*|Y*) return 0 ;; *) return 1 ;; esac
}

kb_of() { du -sk "$1" 2>/dev/null | cut -f1; }

rm_path() { # remove one path, honoring dry-run
  [ -e "$1" ] || return 0
  k=$(kb_of "$1"); k=${k:-0}
  if [ "$DRY" = 1 ]; then
    printf '  %s[dry-run]%s would remove %s %s(%s)%s\n' "$D" "$R" "$1" "$D" "$(human "$k")" "$R"
  else
    rm -rf "$1" && printf '  %sŌ£ō%s removed %s %s(%s)%s\n' "$GRN" "$R" "$1" "$D" "$(human "$k")" "$R"
  fi
  FREED_KB=$((FREED_KB + k))
}

do_clean() {
  FREED_KB=0
  printf '%s%s clean%s%s\n' "$B" "$NAME" "$R" "$([ "$DRY" = 1 ] && printf ' %s(dry run)%s' "$YLW" "$R")"

  # opkg package lists (regenerated by `opkg update`)
  # /var/opkg-lists only: on stock OpenWrt /var is a symlink to /tmp, so
  # listing both paths would show the same directory twice
  if [ -d /var/opkg-lists ]; then
    section "opkg package lists"
    if confirm "Remove opkg lists (opkg update restores them)?"; then
      rm_path /var/opkg-lists
    fi
  fi

  # LuCI web-UI caches (regenerated on next page load)
  found=0
  for d in /tmp/luci-modulecache /tmp/luci-indexcache /tmp/luci-indexcache.*; do
    [ -e "$d" ] && found=1
  done
  if [ "$found" = 1 ]; then
    section "LuCI web-UI caches"
    if confirm "Remove LuCI caches?"; then
      for d in /tmp/luci-modulecache /tmp/luci-indexcache /tmp/luci-indexcache.*; do
        [ -e "$d" ] && rm_path "$d"
      done
    fi
  fi

  # stray downloaded packages
  found=0
  for f in /tmp/*.ipk /tmp/*.apk; do
    [ -f "$f" ] && found=1 && break
  done
  if [ "$found" = 1 ]; then
    section "downloaded packages in /tmp"
    if confirm "Remove downloaded .ipk/.apk files?"; then
      for f in /tmp/*.ipk /tmp/*.apk; do
        [ -f "$f" ] && rm_path "$f"
      done
    fi
  fi

  # rotated logs (only on disk-logging setups; /var/log is RAM on stock OpenWrt)
  found=0
  for f in /var/log/*.gz /var/log/*.old /var/log/*.[0-9]; do
    [ -f "$f" ] && found=1 && break
  done
  if [ "$found" = 1 ]; then
    section "rotated logs in /var/log"
    if confirm "Remove rotated logs?"; then
      for f in /var/log/*.gz /var/log/*.old /var/log/*.[0-9]; do
        [ -f "$f" ] && rm_path "$f"
      done
    fi
  fi

  if [ "$DRY" = 1 ]; then
    printf '\n%sWould free %s%s\n' "$B$GRN" "$(human "$FREED_KB")" "$R"
  else
    printf '\n%sFreed %s%s\n' "$B$GRN" "$(human "$FREED_KB")" "$R"
  fi
}

do_analyze() {
  p="${1:-/}"
  [ -d "$p" ] || { echo "not a directory: $p" >&2; exit 1; }
  printf '%s%s analyze%s\n' "$B" "$NAME" "$R"
  section "$p"
  for e in "$p"/* "$p"/.[!.]*; do
    [ -e "$e" ] || continue
    k=$(kb_of "$e")
    [ -n "$k" ] || continue
    if [ -d "$e" ] && [ ! -L "$e" ]; then t=d; else t=f; fi
    printf '%s\t%s\t%s\n' "$k" "$t" "$e"
  done | sort -rn | head -15 | awk -F'\t' -v c="$CYN" -v d="$D" -v z="$R" '
    NR==1 { max = ($1 < 1 ? 1 : $1) }
    {
      f = int($1*20/max)
      printf "  "
      for (i=0;i<f;i++) printf "Ō¢ł"
      printf "%s", d
      for (i=f;i<20;i++) printf "Ō¢æ"
      printf "%s", z
      k=$1; split("KB MB GB TB", u, " "); s=1   # explicit sep: FS is \t here
      while (k >= 1024 && s < 4) { k /= 1024; s++ }
      h = (s==1 ? sprintf("%d%s",k,u[s]) : sprintf("%.1f%s",k,u[s]))
      n=$3; sub(/.*\//, "", n)
      if ($2 == "d") printf " %8s  %s%s/%s\n", h, c, n, z
      else           printf " %8s  %s\n", h, n
    }'
}

do_status() {
  host=$(cat /proc/sys/kernel/hostname 2>/dev/null)
  pretty=$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME")
  up=$(awk '{s=int($1); printf "%dd %dh %dm", s/86400, (s%86400)/3600, (s%3600)/60}' /proc/uptime 2>/dev/null)
  load=$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null)

  # CPU% over a 1s window
  set -- $(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat); t1=$1; i1=$2
  sleep 1
  set -- $(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat); t2=$1; i2=$2
  dt=$((t2 - t1)); di=$((i2 - i1)); cpu=0
  [ "$dt" -gt 0 ] && cpu=$(( (dt - di) * 100 / dt ))

  set -- $(awk '/^MemTotal:/{t=$2} /^MemAvailable:/{a=$2} /^MemFree:/{f=$2}
    END{ if (a=="") a=f; print t, t-a }' /proc/meminfo)
  mt=$1; mu=$2; mp=0
  [ "$mt" -gt 0 ] && mp=$((mu * 100 / mt))

  temp=""
  for z in /sys/class/thermal/thermal_zone*/temp; do
    [ -r "$z" ] && { temp=$(( $(cat "$z") / 1000 )); break; }
  done

  # health: same idea as full mole, honest heuristic
  hs=100
  [ "$mp" -gt 80 ] && hs=$((hs - (mp - 80)))
  [ "$cpu" -gt 80 ] && hs=$((hs - (cpu - 80) / 2))
  [ -n "$temp" ] && [ "$temp" -gt 75 ] && hs=$((hs - (temp - 75)))
  [ "$hs" -lt 0 ] && hs=0
  if   [ "$hs" -ge 90 ]; then dot="$GRNŌŚÅ$R"; lbl="All clear"
  elif [ "$hs" -ge 70 ]; then dot="$YLWŌŚÉ$R"; lbl="Fine"
  else                        dot="$REDŌŚŗ$R"; lbl="Stressed"; fi

  printf '%s     ___%s\n' "$YLW" "$R"
  printf '%s  __(o o)%s   %s%s%s v%s  %s%s ┬Ę %s%s\n' \
    "$YLW" "$R" "$B$MAG" "$NAME" "$R" "$VERSION" "$D" "${host:-?}" "${pretty:-Linux}" "$R"
  printf '%s ~\\(  mm )%s  Health %s %s%s%s %s  %sup %s ┬Ę load %s%s\n\n' \
    "$YLW" "$R" "$dot" "$B" "$hs" "$R" "$lbl" "$D" "${up:-?}" "${load:-?}" "$R"

  printf ' %-5s %s %3d%%\n' "CPU" "$(meter "$cpu")" "$cpu"
  printf ' %-5s %s %3d%%  %s%s / %s%s\n' "MEM" "$(meter "$mp")" "$mp" \
    "$D" "$(human "$mu")" "$(human "$mt")" "$R"
  df -k / /overlay 2>/dev/null | awk 'NR>1 && !seen[$6]++ {gsub("%","",$5); print $6, $2, $3, $5}' \
  | while read -r mnt sz used pct; do
      printf ' %-5s %s %3d%%  %s%s  %s / %s%s\n' "DISK" "$(meter "$pct")" "$pct" \
        "$D" "$mnt" "$(human "$used")" "$(human "$sz")" "$R"
    done
  [ -n "$temp" ] && printf ' %-5s %s┬░C\n' "TEMP" "$temp"
  awk -F'[: ]+' '/:/{ if ($2 != "lo") { rx += $3; tx += $11 } }
    END{ printf " %-5s rx %.1fMB ┬Ę tx %.1fMB since boot\n", "NET", rx/1048576, tx/1048576 }' /proc/net/dev 2>/dev/null
  return 0
}

do_update() {
  url="https://raw.githubusercontent.com/ccyisafool/mole-for-ubuntu-and-friends/main/lite/mo-lite"
  self=$(readlink -f "$0" 2>/dev/null || echo "$0")
  tmp="/tmp/mo-lite.new.$$"
  printf '%s%s update%s ŌĆö installed v%s\n' "$B" "$NAME" "$R" "$VERSION"
  if ! wget -q -O "$tmp" "$url" 2>/dev/null; then
    rm -f "$tmp"
    printf '  %sŌ£Ś%s download failed (GitHub unreachable, or wget lacks HTTPS) ŌĆö current install untouched\n' "$RED" "$R" >&2
    exit 1
  fi
  # refuse anything that doesn't look like this script (captive portal, truncation)
  if ! head -1 "$tmp" | grep -q '^#!/bin/sh' || [ "$(wc -c <"$tmp")" -lt 2000 ]; then
    rm -f "$tmp"
    printf '  %sŌ£Ś%s downloaded file does not look like mo-lite ŌĆö refusing to install\n' "$RED" "$R" >&2
    exit 1
  fi
  new=$(sed -n 's/^VERSION="\(.*\)"/\1/p' "$tmp" | head -1)
  if [ "$new" = "$VERSION" ]; then
    rm -f "$tmp"
    printf '  %sŌ£ō%s already up to date (v%s)\n' "$GRN" "$R" "$VERSION"
    exit 0
  fi
  if [ "$DRY" = 1 ]; then
    rm -f "$tmp"
    printf '  %s[dry-run]%s would replace %s: v%s -> v%s\n' "$D" "$R" "$self" "$VERSION" "${new:-?}"
    exit 0
  fi
  chmod +x "$tmp"
  if mv "$tmp" "$self" 2>/dev/null; then
    printf '  %sŌ£ō%s updated %sv%s ŌåÆ v%s%s\n' "$GRN" "$R" "$B" "$VERSION" "${new:-?}" "$R"
    exit 0
  fi
  rm -f "$tmp"
  printf '  %sŌ£Ś%s could not replace %s (not writable?)\n' "$RED" "$R" "$self" >&2
  exit 1
}

CMD=""
ARG=""
for a in "$@"; do
  case "$a" in
    -n) DRY=1 ;;
    -y) YES=1 ;;
    -h|--help) usage; exit 0 ;;
    *) if [ -z "$CMD" ]; then CMD="$a"; else ARG="$a"; fi ;;
  esac
done

case "$CMD" in
  clean)   do_clean ;;
  analyze) do_analyze "$ARG" ;;
  status)  do_status ;;
  update)  do_update ;;
  "")      do_status ;;                # bare command: show the dashboard
  *)       usage; exit 1 ;;
esac
